# Copy to .env and edit. All optional — sensible defaults are used.
PORT=8080
# Set an admin password on FIRST run (otherwise a random one is generated and printed/saved to data/ADMIN_CREDENTIALS.txt)
ADMIN_PASSWORD=
# Set to 1 only when serving over HTTPS (makes the login cookie HTTPS-only)
SECURE_COOKIE=0
# Where the database + uploads live (default: ./data). Back this folder up.
DATA_DIR=
